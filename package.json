{
  "name": "ahk-talent-bridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:push:turso": "node scripts/push-turso.mjs",
    "db:migrate:turso": "node scripts/migrate-turso.mjs",
    "db:sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:extra": "tsx prisma/seed-extra.ts",
    "db:translate:de": "tsx scripts/add-de-translations.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@libsql/client": "^0.14.0",
    "@prisma/adapter-libsql": "^6.2.1",
    "@prisma/client": "^6.2.1",
    "@vercel/blob": "^2.5.0",
    "clsx": "^2.1.1",
    "inngest": "^4.11.0",
    "lucide-react": "^0.473.0",
    "next": "^15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
