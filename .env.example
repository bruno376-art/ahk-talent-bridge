# ---- Banco de dados (Turso / libSQL) ----
# Local (dev):  file:./prisma/dev.db
# Produção:     libsql://<seu-db>.turso.io
DATABASE_URL="file:./prisma/dev.db"
DATABASE_AUTH_TOKEN=""

# ---- IA (Anthropic) ----
ANTHROPIC_API_KEY=""

# ---- E-mail (opcional, Resend). Sem chave => e-mails apenas logados no console ----
RESEND_API_KEY=""
EMAIL_FROM="AHK Talent Bridge <talentbridge@example.org>"

# ---- Admin (backoffice mínimo) ----
# Senha do backoffice + segredo para assinar o cookie de sessão do admin.
ADMIN_PASSWORD="troque-esta-senha"
ADMIN_SESSION_SECRET="gere-um-segredo-aleatorio-longo"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Inngest ----
# Dev local: INNGEST_DEV=1 (roda sem signing key).
# Produção: definir INNGEST_SIGNING_KEY e INNGEST_EVENT_KEY.
INNGEST_DEV="1"
